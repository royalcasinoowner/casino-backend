# Casino Backend — Environment Variables
# Copy this file to .env and fill in your values before starting the server.

# ─── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:yourpassword@localhost:5432/betting

# ─── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ─── Security ──────────────────────────────────────────────────────────────
# ADMIN_API_KEY: Required for all /api/admin/* HTTP endpoints.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_API_KEY=CHANGE_ME_generate_a_strong_random_key_here

# ALLOWED_ORIGINS: Comma-separated list of allowed CORS origins.
# Add your production frontend URL and Capacitor local URL.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,capacitor://localhost,http://localhost

# GITHUB_WEBHOOK_SECRET: Secret configured in your GitHub repo webhook settings.
# Required for the /api/github-webhook auto-deploy endpoint.
# Set the same value in GitHub → Repo Settings → Webhooks → Secret.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GITHUB_WEBHOOK_SECRET=CHANGE_ME_generate_a_strong_random_key_here

# ─── Server ────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Firebase Push Notifications (optional) ────────────────────────────────
# If you have a firebase-service-account.json, Firebase Admin will auto-load it.
# Leave blank to run in simulated push mode.
